# =============================================================================
# .env.example — copy this to .env and fill in your values
# =============================================================================
# NEVER commit .env to git. This file is safe to commit — it contains
# only keys with placeholder values, no real secrets.
#
# Usage:
#   cp .env.example .env
#   then edit .env with your actual values
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_NAME=my-project
APP_ENV=development          # development | staging | production
APP_DEBUG=true
APP_LOG_LEVEL=INFO           # DEBUG | INFO | WARNING | ERROR | CRITICAL

# ---------------------------------------------------------------------------
# Server (if running a web app)
# ---------------------------------------------------------------------------
# APP_HOST=0.0.0.0
# APP_PORT=8000

# ---------------------------------------------------------------------------
# Database (uncomment and fill in when needed)
# ---------------------------------------------------------------------------
# DATABASE_URL=postgresql://user:password@localhost:5432/mydb
# DATABASE_POOL_SIZE=5

# ---------------------------------------------------------------------------
# Redis / Cache (uncomment when needed)
# ---------------------------------------------------------------------------
# REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# External APIs (add your services here)
# ---------------------------------------------------------------------------
# SOME_API_KEY=your-api-key-here
# SOME_API_SECRET=your-api-secret-here
# SOME_API_BASE_URL=https://api.example.com/v1

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
# SECRET_KEY=change-me-to-a-long-random-string
# ALLOWED_HOSTS=localhost,127.0.0.1

# ---------------------------------------------------------------------------
# Docker / GHCR (used in local development with docker-compose)
# ---------------------------------------------------------------------------
# REGISTRY=ghcr.io
# IMAGE_NAME=a-endari/python-template
